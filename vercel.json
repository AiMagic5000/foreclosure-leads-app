{
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/webcast/drip",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/lander",
      "destination": "/lander/index.html"
    },
    {
      "source": "/talks",
      "destination": "/talks/index.html"
    },
    {
      "source": "/talks/",
      "destination": "/talks/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
